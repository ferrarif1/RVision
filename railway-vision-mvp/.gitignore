# macOS
.DS_Store

# Python cache
__pycache__/
*.pyc

# Local generated certs/keys (regenerate via docker/scripts/generate_local_materials.sh)
docker/certs/*
!docker/certs/.gitkeep

docker/keys/*
!docker/keys/.gitkeep

edge/keys/*
!edge/keys/.gitkeep

# Runtime-generated uploads, screenshots and QA reports
backend/app/uploads/*
!backend/app/uploads/.gitkeep
!backend/app/uploads/open_models/
!backend/app/uploads/open_models/**
backend/app/uploads/screenshots/*
!backend/app/uploads/screenshots/.gitkeep
docs/qa/reports/*.json
!docs/qa/reports/.gitkeep
