# Optional env file for docker compose overrides
POSTGRES_DB=vistral
POSTGRES_USER=railway
POSTGRES_PASSWORD=railway123
JWT_SECRET=CHANGE_ME_IN_PROD
# Optional host port overrides (avoid local port conflicts)
POSTGRES_PORT=55432
REDIS_PORT=56379
BACKEND_PORT=8000
FRONTEND_PORT=8443

# ---- Registry / mirror overrides (for intranet or restricted network) ----
# POSTGRES_IMAGE=postgres:16-alpine
# REDIS_IMAGE=redis:7-alpine
# PYTHON_BASE_IMAGE=python:3.11-slim
# EDGE_PYTHON_BASE_IMAGE=python:3.11-slim
POSTGRES_IMAGE=postgres:16-alpine
REDIS_IMAGE=redis:7-alpine
PYTHON_BASE_IMAGE=python:3.11-slim
EDGE_PYTHON_BASE_IMAGE=python:3.11-slim
NGINX_BASE_IMAGE=nginx:1.27-alpine

# ---- Python package mirror (optional) ----
PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
PIP_TRUSTED_HOST=pypi.tuna.tsinghua.edu.cn
PIP_EXTRA_INDEX_URL=

