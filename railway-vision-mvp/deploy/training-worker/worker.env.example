# Vistral training worker environment template
# Vistral 训练 worker 环境变量模板

# Control plane base URL / 控制面地址
TRAINING_BACKEND_BASE_URL=http://localhost:8000

# Worker identity / worker 身份标识
TRAINING_WORKER_CODE=training-worker-001
TRAINING_WORKER_TOKEN=replace-with-bootstrap-token
TRAINING_WORKER_HOST=10.0.0.21

# Local paths / 本机路径
TRAINING_BACKEND_ROOT=./backend
TRAINING_WORK_DIR=/var/lib/vistral-training-worker
MODEL_DECRYPT_KEY=./keys/model_decrypt.key
MODEL_ENCRYPT_KEY=./keys/model_encrypt.key
MODEL_SIGN_PRIVATE_KEY=./keys/model_sign_private.pem

# Package metadata / 候选模型包元数据
TRAINING_OUTPUT_MODEL=candidate_model.bin
TRAINING_RUNTIME=python
TRAINING_MODEL_TYPE=expert
TRAINING_PLUGIN_NAME=car_number_ocr
TRAINING_ROUND=round-1
TRAINING_DATASET_LABEL=car-number-worker-dataset
TRAINING_SUMMARY=Candidate generated by Vistral training worker

# Pull / control timing / 拉取与控制轮询参数
TRAINING_POLL_SECONDS=10
TRAINING_PULL_LIMIT=1
TRAINING_CONTROL_POLL_SECONDS=2

# Builtin trainer fallback / 内置训练器回退模式
# builtin: use lightweight built-in trainer / 使用内置轻量训练器
# mock: produce a placeholder candidate artifact / 生成占位候选模型
TRAINING_TRAINER_MODE=builtin

# Optional external trainer command / 可选的外部训练命令
# Example / 示例:
# TRAINING_TRAINER_CMD=python3 /opt/trainers/run_train.py --train {train_manifest} --val {val_manifest} --base {base_model_path} --out {output_model_path} --metrics {metrics_json}
# Trainer exit code contract / 训练器退出码契约:
# 10=config_error(不可重试) 11=input_contract_error(不可重试) 12=data_error(不可重试)
# 20=runtime_error(可重试) 21=dependency_unavailable(可重试) 22=interrupted(可重试)
# metrics_json schema / 指标文件格式:
# {"epochs":2,"train_loss":0.1,"val_loss":0.08,"val_accuracy":0.93,"history":[{"epoch":1,"train_loss":0.2,"val_loss":0.12,"val_accuracy":0.89}],"best_checkpoint":{"epoch":2,"metric":"val_accuracy","value":0.93,"path":"checkpoints/best.pt"}}
TRAINING_TRAINER_CMD=

# Worker labels / worker 标签（用于控制面筛选）
TRAINING_WORKER_LABELS={"kind":"gpu","site":"lab-a"}

# Worker resources / worker 资源摘要（用于展示与调度）
TRAINING_WORKER_RESOURCES={"gpu_mem_mb":24576,"cpu":16}
